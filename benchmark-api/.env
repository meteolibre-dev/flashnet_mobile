# ── GCS ──────────────────────────────────────────────────────────────────
# Source bucket with forecast TIFFs
BUCKET_NAME=inference_result_meteolibre_forecast
FORECASTS_PREFIX=forecasts

# ── Server ───────────────────────────────────────────────────────────────
PORT=8080

# ── Model bounds (EPSG:4326) ────────────────────────────────────────────
BOUNDS_WEST=-10.0
BOUNDS_EAST=33.0
BOUNDS_SOUTH=33.0
BOUNDS_NORTH=65.0

# ── Forecast steps ──────────────────────────────────────────────────────
MAX_FORECAST_STEPS=18
STEP_MINUTES=10

# ── Precipitation threshold (mm/h) ──────────────────────────────────────
RATE_THRESHOLD=0.1
