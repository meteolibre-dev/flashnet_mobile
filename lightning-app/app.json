{
  "expo": {
    "name": "FlashNet",
    "slug": "flashnet-y50onk",
    "version": "1.10.0",
    "orientation": "portrait",
    "icon": "./public/logo_small.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "dev.meteolibre.lightningapp"
    },
    "android": {
      "package": "dev.meteolibre.lightningapp",
      "versionCode": 31,
      "permissions": [
        "INTERNET",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-build-properties",
      [
        "@maplibre/maplibre-react-native",
        {
          "android": {
            "RNMGLPackage": true
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "94c335b0-cece-42b4-8ec2-4aed1f3113ef"
      }
    }
  }
}